# OS cruft
.DS_Store

# Editor/runtime state we don't want tracked
*.swp

# nvim runtime (regenerated; track lazy-lock.json deliberately if you want pinned plugins)
nvim/.config/nvim/lazy-lock.json

# fish machine-specific universal variables (intentionally not managed)
fish/.config/fish/fish_variables

# alacritty editor-generated backups
alacritty/.config/alacritty/*.bak
